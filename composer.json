{
    "name": "psimandl/contao-workflow",
    "type": "contao-bundle",
    "description": "Contao 5.3 bundle for a token-based query workflow: CSV/XLSX import, individual prefilled forms with signature, PDF generation and admin overview.",
    "license": "proprietary",
    "version": "2.9.5",
    "authors": [
        {
            "name": "Peter Simandl",
            "email": "peter.simandl86@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-zip": "*",
        "contao/core-bundle": "^5.3",
        "contao/manager-plugin": "^2.0",
        "doctrine/dbal": "^3.6 || ^4.0",
        "menatwork/contao-multicolumnwizard-bundle": "^3.6",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.0 || ^3.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/filesystem": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0",
        "terminal42/dcawizard": "^3.0",
        "terminal42/notification_center": "^2.0",
        "webklex/php-imap": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Psimandl\\WorkflowBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Psimandl\\WorkflowBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "contao/manager-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "contao-manager-plugin": "Psimandl\\WorkflowBundle\\ContaoManager\\Plugin"
    },
    "archive": {
        "exclude": ["/vendor", "/composer.lock", "/.gitignore", "/.phpunit.result.cache", "/.phpunit.cache", "/dist", "/tests", "/phpunit.xml.dist", "/docs/dev"]
    }
}
